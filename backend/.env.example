# ============================================
# VerifyAI Backend — Environment Variables
# ============================================
# Copy this file to .env and fill in your values.

# --- Database ---
# Development: SQLite (default if not set)
# Production: PostgreSQL connection string
DATABASE_URL=postgresql://verifyai:verifyai_secret@localhost:5432/verifyai
POSTGRES_USER=verifyai
POSTGRES_PASSWORD=verifyai_secret
POSTGRES_DB=verifyai

# --- API Keys ---
# Google Fact Check Tools API (optional, graceful degradation if missing)
# Get one at: https://developers.google.com/fact-check/tools/api
GOOGLE_FACT_CHECK_API_KEY=your_google_api_key_here

# Anthropic Claude API (optional, used for natural-language explanations)
# Get one at: https://console.anthropic.com/
ANTHROPIC_API_KEY=your_anthropic_api_key_here

# --- App Settings ---
# development | production
APP_ENV=development
DEBUG=true

# Comma-separated allowed origins for CORS
CORS_ORIGINS=http://localhost:3000

# --- Model Settings ---
# Path to trained ML models (relative to backend/ directory)
MODEL_PATH=ml/models/
